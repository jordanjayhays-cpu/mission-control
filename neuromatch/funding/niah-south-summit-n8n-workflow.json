    {
      "parameters": {
        "jsCode": "// Niah AI Matching Engine\n// Reads all attendees, scores compatibility, generates match pairs\n\nconst attendees = $input.all();\nconst matches = [];\n\n// Group by role\nconst investors = attendees.filter(a => ajson.role?.toLowerCase().includes('investor') || ajson.role?.toLowerCase().includes('lp'));\nconst startups = attendees.filter(a => ajson.role?.toLowerCase().includes('founder') || ajson.role?.toLowerCase().includes('ceo') || ajson.role?.toLowerCase().includes('startup'));\nconst corporates = attendees.filter(a => ajson.role?.toLowerCase().includes('corporate') || ajson.role?.toLowerCase().includes('business'));\n\n// Score function\nfunction score(a, b) {\n  let s = 0;\n  // Company complementarity\n  if (a.json.what_can_you_help && b.json.who_to_meet) {\n    const help = a.json.what_can_you_help.toLowerCase();\n    const need = b.json.who_to_meet.toLowerCase();\n    if (help.some(h => need.includes(h))) s += 3;\n  }\n  // Role geometry: investor-startup, corporate-startup, etc.\n  const geo = {'investor': startups, 'startup': [...investors, ...corporates], 'corporate': startups};\n  const aType = investors.includes(a) ? 'investor' : startups.includes(a) ? 'startup' : 'corporate';\n  if (geo[aType]?.includes(b)) s += 5;\n  // preferences overlap\n  if (a.json.preferences && b.json.preferences) {\n    const ap = a.json.preferences.split(',').map(x=>x.trim());\n    const bp = b.json.preferences.split(',').map(x=>x.trim());\n    const overlap = ap.filter(x => bp.includes(x)).length;\n    s += overlap;\n  }\n  return s;\n}\n\n// Generate top-3 matches per attendee\nfor (const att of attendees) {\n  const scores = attendees\n    .filter(a => a.json.email !== att.json.email)\n    .map(a => ({ person: a, score: score(att, a) }))\n    .sort((a, b) => b.score - a.score)\n    .slice(0, 3)\n    .filter(x => x.score > 0);\n  \n  for (const m of scores) {\n    matches.push({\n      json: {\n        person_a: att.json.name,\n        email_a: att.json.email,\n        person_b: m.person.json.name,\n        email_b: m.person.json.email,\n        score: m.score,\n        rationale: `${att.json.name} is looking for ${att.json.who_to_meet} — ${m.person.json.name} can help with ${m.person.json.what_can_you_help}`,\n        status: 'Pending',\n        created_at: new Date().toISOString()\n      }\n    });\n  }\n}\n\nreturn matches.slice(0, 50); // Cap at 50 match pairs per run"
      },
      "id": "ai-match",
      "name": "AI Matching Engine",
      "type": "n8n-nodes-base.code",
