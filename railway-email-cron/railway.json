{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacks": {
      "languages": {
        "python": {
          "version": "3.12"
        }
      }
    }
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  },
  "cronJobs": [
    {
      "name": "neuro-email-daily",
      "command": "cd /tmp/neuro-email-cron && python email_sender.py",
      "schedule": "0 9 * * *",
      "description": "Sends one neuro lead email per day, auto-follows on days 3 and 7"
    }
  ],
  "vars": {
    "GMAIL_USER": "jordanjayhays@gmail.com",
    "GMAIL_APP_PASSWORD": "",
    "SENDER_NAME": "Jordan"
  }
}